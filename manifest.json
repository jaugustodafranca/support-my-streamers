{
  "manifest_version": 3,
  "name": "Support My Streamers",
  "version": "0.1.0",
  "description": "Rotaciona entre os streamers que você segue na Twitch, assistindo alguns por vez.",
  "permissions": ["identity", "storage", "tabs", "tabGroups", "alarms"],
  "host_permissions": ["https://api.twitch.tv/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Support My Streamers",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html"
}
